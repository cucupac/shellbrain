#!/usr/bin/env bash
set -eo pipefail

SHELLBRAIN_LEGACY_PATH_MARKER_BEGIN="# >>> shellbrain path >>>"
SHELLBRAIN_LEGACY_PATH_MARKER_END="# <<< shellbrain path <<<"
SHELLBRAIN_SOURCE_MARKER_BEGIN="# >>> shellbrain source >>>"
SHELLBRAIN_SOURCE_MARKER_END="# <<< shellbrain source <<<"
SHELLBRAIN_SOURCE_SECTION_BORDER="# ============================================================================ #"
SHELLBRAIN_SOURCE_SECTION_HEADER="# SHELLBRAIN"
SHELLBRAIN_SOURCE_LINE='[ -f "${XDG_CONFIG_HOME:-$HOME/.config}/shellbrain/path.sh" ] && . "${XDG_CONFIG_HOME:-$HOME/.config}/shellbrain/path.sh"'
PATH_SNIPPET=""
PATH_TARGETS=()
PATH_SETUP_WARNING=""

config_root() {
  if [ -n "${XDG_CONFIG_HOME:-}" ]; then
    printf '%s\n' "$XDG_CONFIG_HOME"
    return
  fi
  printf '%s\n' "$HOME/.config"
}

shellbrain_path_snippet() {
  printf '%s\n' "$(config_root)/shellbrain/path.sh"
}

shellbrain_fish_conf() {
  printf '%s\n' "$(config_root)/fish/conf.d/shellbrain.fish"
}

append_path_target() {
  local target="$1"
  local existing

  [ -n "$target" ] || return 0

  for existing in "${PATH_TARGETS[@]}"; do
    [ "$existing" = "$target" ] && return 0
  done

  PATH_TARGETS+=("$target")
}

render_path_targets() {
  local rendered=""
  local target=""

  for target in "${PATH_TARGETS[@]}"; do
    if [ -n "$rendered" ]; then
      rendered="$rendered, $target"
      continue
    fi
    rendered="$target"
  done

  printf '%s\n' "$rendered"
}

file_contains_marker() {
  local file="$1"
  local marker="$2"

  grep -Fq "$marker" "$file" 2>/dev/null
}

remove_managed_block() {
  local file="$1"
  local marker_begin="$2"
  local marker_end="$3"
  local temp_file="${file}.shellbrain.tmp"

  [ -f "$file" ] || return 0

  awk -v marker_begin="$marker_begin" -v marker_end="$marker_end" '
    $0 == marker_begin { skipping = 1; next }
    $0 == marker_end { skipping = 0; next }
    skipping != 1 { print }
  ' "$file" > "$temp_file"
  mv "$temp_file" "$file"
}

remove_shellbrain_section_block() {
  local file="$1"
  local temp_file="${file}.shellbrain.tmp"

  [ -f "$file" ] || return 0

  awk \
    -v border="$SHELLBRAIN_SOURCE_SECTION_BORDER" \
    -v header="$SHELLBRAIN_SOURCE_SECTION_HEADER" \
    -v source_line="$SHELLBRAIN_SOURCE_LINE" '
    function flush_buffer() {
      if (buffer_count >= 1) print buffer1
      if (buffer_count >= 2) print buffer2
      if (buffer_count >= 3) print buffer3
      if (buffer_count >= 4) print buffer4
      buffer_count = 0
      buffer1 = ""
      buffer2 = ""
      buffer3 = ""
      buffer4 = ""
    }

    {
      if (buffer_count == 0) {
        if ($0 == border) {
          buffer_count = 1
          buffer1 = $0
          next
        }
        print
        next
      }

      if (buffer_count == 1) {
        if ($0 == header) {
          buffer_count = 2
          buffer2 = $0
          next
        }
        flush_buffer()
        print
        next
      }

      if (buffer_count == 2) {
        if ($0 == border) {
          buffer_count = 3
          buffer3 = $0
          next
        }
        flush_buffer()
        print
        next
      }

      if (buffer_count == 3) {
        if ($0 == "") {
          buffer_count = 4
          buffer4 = $0
          next
        }
        flush_buffer()
        print
        next
      }

      if (buffer_count == 4) {
        if ($0 == source_line) {
          buffer_count = 0
          buffer1 = ""
          buffer2 = ""
          buffer3 = ""
          buffer4 = ""
          next
        }
        flush_buffer()
        print
        next
      }
    }

    END {
      flush_buffer()
    }
  ' "$file" > "$temp_file"
  mv "$temp_file" "$file"
}

render_posix_source_block() {
  cat <<'EOF'
# ============================================================================ #
# SHELLBRAIN
# ============================================================================ #

[ -f "${XDG_CONFIG_HOME:-$HOME/.config}/shellbrain/path.sh" ] && . "${XDG_CONFIG_HOME:-$HOME/.config}/shellbrain/path.sh"
EOF
}

file_contains_shellbrain_block() {
  local file="$1"

  file_contains_marker "$file" "$SHELLBRAIN_LEGACY_PATH_MARKER_BEGIN" && return 0
  file_contains_marker "$file" "$SHELLBRAIN_SOURCE_MARKER_BEGIN" && return 0

  grep -Fq "$SHELLBRAIN_SOURCE_SECTION_HEADER" "$file" 2>/dev/null \
    && grep -Fq "$SHELLBRAIN_SOURCE_LINE" "$file" 2>/dev/null
}

ensure_profile_sources_snippet() {
  local profile="$1"
  local source_block="$2"

  mkdir -p "$(dirname "$profile")" || return 1
  touch "$profile" || return 1

  remove_managed_block "$profile" "$SHELLBRAIN_LEGACY_PATH_MARKER_BEGIN" "$SHELLBRAIN_LEGACY_PATH_MARKER_END" || return 1
  remove_managed_block "$profile" "$SHELLBRAIN_SOURCE_MARKER_BEGIN" "$SHELLBRAIN_SOURCE_MARKER_END" || return 1
  remove_shellbrain_section_block "$profile" || return 1

  {
    printf '\n'
    printf '%s\n' "$source_block"
  } >> "$profile" || return 1

  append_path_target "$profile"
}

write_posix_path_snippet() {
  local bin_dir="$1"
  local snippet_path

  snippet_path="$(shellbrain_path_snippet)"
  mkdir -p "$(dirname "$snippet_path")" || return 1
  if ! cat > "$snippet_path" <<EOF
# shellbrain managed path
case ":\$PATH:" in
  *":$bin_dir:"*) ;;
  *) export PATH="$bin_dir:\$PATH" ;;
esac
EOF
  then
    return 1
  fi
  PATH_SNIPPET="$snippet_path"
}

write_fish_path_config() {
  local bin_dir="$1"
  local fish_conf

  fish_conf="$(shellbrain_fish_conf)"
  mkdir -p "$(dirname "$fish_conf")" || return 1
  if ! cat > "$fish_conf" <<EOF
# shellbrain managed path
if not contains -- "$bin_dir" \$PATH
    set -gx PATH "$bin_dir" \$PATH
end
EOF
  then
    return 1
  fi
  append_path_target "$fish_conf"
}

ensure_user_bin_on_shell_path() {
  local bin_dir="$1"
  local source_block=""
  local profile=""
  local current_shell="${SHELL##*/}"
  local legacy_profiles=(
    "$HOME/.zprofile"
    "$HOME/.zshrc"
    "$HOME/.bash_profile"
    "$HOME/.bashrc"
    "$HOME/.profile"
  )

  [ -n "$bin_dir" ] || return 0

  PATH_SNIPPET=""
  PATH_TARGETS=()
  write_posix_path_snippet "$bin_dir" || return 1
  source_block="$(render_posix_source_block)"

  for profile in "${legacy_profiles[@]}"; do
    if file_contains_shellbrain_block "$profile"; then
      ensure_profile_sources_snippet "$profile" "$source_block" || return 1
    fi
  done

  case "$current_shell" in
    zsh)
      ensure_profile_sources_snippet "$HOME/.zprofile" "$source_block" || return 1
      ensure_profile_sources_snippet "$HOME/.zshrc" "$source_block" || return 1
      ;;
    bash)
      ensure_profile_sources_snippet "$HOME/.bash_profile" "$source_block" || return 1
      ensure_profile_sources_snippet "$HOME/.bashrc" "$source_block" || return 1
      ;;
    fish)
      write_fish_path_config "$bin_dir" || return 1
      ;;
    *)
      ensure_profile_sources_snippet "$HOME/.profile" "$source_block" || return 1
      ;;
  esac
}

echo "upgrading shellbrain..."
echo ""

PY=""
for candidate in python3.14 python3.13 python3.12 python3.11 python3 python; do
  if command -v "$candidate" &>/dev/null; then
    minor=$("$candidate" -c "import sys; print(sys.version_info.minor)" 2>/dev/null) || continue
    if [ "$minor" -ge 11 ]; then
      PY="$candidate"
      break
    fi
  fi
done

if [ -z "$PY" ]; then
  if command -v python3 &>/dev/null || command -v python &>/dev/null; then
    FOUND_VER=$(python3 -c "import sys; print(f'{sys.version_info.major}.{sys.version_info.minor}')" 2>/dev/null || python -c "import sys; print(f'{sys.version_info.major}.{sys.version_info.minor}')" 2>/dev/null)
    echo "error: python $FOUND_VER found, but Python 3.11+ required."
  else
    echo "error: python not found."
  fi
  if [[ "$OSTYPE" =~ ^darwin ]]; then
    echo "install it with: brew install python"
  else
    echo "install Python 3.11+ and try again."
  fi
  exit 1
fi

PY_VERSION=$($PY -c "import sys; print(f'{sys.version_info.major}.{sys.version_info.minor}')")
echo "using $PY ($PY_VERSION)"

$PY -m pip install --user --upgrade --break-system-packages shellbrain 2>/dev/null \
  || $PY -m pip install --user --upgrade shellbrain 2>/dev/null \
  || $PY -m pip install --upgrade shellbrain

SHELLBRAIN=""
USER_BIN=$($PY -c "import sysconfig; print(sysconfig.get_path('scripts', 'posix_user'))" 2>/dev/null)

if [ -n "$USER_BIN" ] && [ -x "$USER_BIN/shellbrain" ]; then
  SHELLBRAIN="$USER_BIN/shellbrain"
elif command -v shellbrain &>/dev/null; then
  SHELLBRAIN=shellbrain
fi

if [ -z "$SHELLBRAIN" ]; then
  for dir in "$HOME/.local/bin" "$HOME/Library/Python/$PY_VERSION/bin" "/usr/local/bin" "/opt/homebrew/bin"; do
    if [ -x "$dir/shellbrain" ]; then
      SHELLBRAIN="$dir/shellbrain"
      break
    fi
  done
fi

if [ -z "$SHELLBRAIN" ]; then
  echo ""
  echo "shellbrain was upgraded but could not be found."
  echo "restart your terminal, then run: shellbrain init"
  exit 0
fi

if [ -n "$USER_BIN" ] && [ -d "$USER_BIN" ]; then
  if ! ensure_user_bin_on_shell_path "$USER_BIN"; then
    PATH_SNIPPET=""
    PATH_TARGETS=()
    PATH_SETUP_WARNING="warning: could not update shell PATH wiring under $(config_root). shellbrain is installed at $SHELLBRAIN, but future shells may not find it automatically. fix permissions on $(config_root) and rerun the installer, or add $USER_BIN to PATH manually."
  fi
fi

echo ""
echo "re-initializing..."
echo "  shellbrain init will ask how it should store data."
echo "  default: let shellbrain set up local PostgreSQL + pgvector for you."
echo "  advanced: use an existing PostgreSQL + pgvector database."
echo ""
$SHELLBRAIN init

echo ""
echo "next: start a repo session in codex or claude code."
echo "  docs: shellbrain.ai/humans"
if [ -n "$PATH_SNIPPET" ]; then
  echo "  cli path: ensured via $PATH_SNIPPET"
fi
if [ "${#PATH_TARGETS[@]}" -gt 0 ]; then
  echo "  shell path wiring: $(render_path_targets)"
fi
if [ -n "$PATH_SETUP_WARNING" ]; then
  echo "  $PATH_SETUP_WARNING"
fi
echo ""
echo "shellbrain. knowledge compounds."
