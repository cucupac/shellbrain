#!/usr/bin/env bash
set -eo pipefail

echo "installing shellbrain..."
echo ""

# Find python
if command -v python3 &>/dev/null; then
  PY=python3
elif command -v python &>/dev/null; then
  PY=python
else
  echo "error: python not found. install python3 first."
  exit 1
fi

# Check python version (shellbrain requires 3.11+)
PY_VERSION=$($PY -c "import sys; print(f'{sys.version_info.major}.{sys.version_info.minor}')")
PY_MINOR=$($PY -c "import sys; print(sys.version_info.minor)")
if [ "$PY_MINOR" -lt 11 ]; then
  echo "error: python $PY_VERSION found, but shellbrain requires python 3.11+."
  if [[ "$OSTYPE" =~ ^darwin ]]; then
    echo "install it with: brew install python@3.13"
  else
    echo "install python 3.11+ and try again."
  fi
  exit 1
fi

# Install with fallback chain
$PY -m pip install --user --break-system-packages shellbrain 2>/dev/null \
  || $PY -m pip install --user shellbrain 2>/dev/null \
  || $PY -m pip install shellbrain

# Source profile so shellbrain is on PATH
case $SHELL in
  */zsh)  [ -f "$HOME/.zprofile" ] && . "$HOME/.zprofile" 2>/dev/null; [ -f "$HOME/.zshrc" ] && . "$HOME/.zshrc" 2>/dev/null ;;
  */bash) [ -f "$HOME/.bashrc" ] && . "$HOME/.bashrc" 2>/dev/null; [ -f "$HOME/.bash_profile" ] && . "$HOME/.bash_profile" 2>/dev/null ;;
esac

# Verify shellbrain is available
if ! command -v shellbrain &>/dev/null; then
  echo ""
  echo "shellbrain was installed but is not on PATH."
  echo "restart your terminal, then run: shellbrain init"
  exit 0
fi

echo ""
echo "initializing..."
echo ""

shellbrain init

echo ""
echo "shellbrain. knowledge compounds."
