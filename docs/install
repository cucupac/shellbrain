#!/usr/bin/env bash
set -eo pipefail

echo "installing shellbrain..."

# Find python
if command -v python3 &>/dev/null; then
  PY=python3
elif command -v python &>/dev/null; then
  PY=python
else
  echo "error: python not found. install python3 first."
  exit 1
fi

# Install with fallback chain
$PY -m pip install --user --break-system-packages shellbrain 2>/dev/null \
  || $PY -m pip install --user shellbrain 2>/dev/null \
  || $PY -m pip install shellbrain

echo ""
echo "installed. initializing..."

# Source profile so shellbrain is on PATH
case $SHELL in
  */zsh)  [ -f "$HOME/.zprofile" ] && . "$HOME/.zprofile" 2>/dev/null; [ -f "$HOME/.zshrc" ] && . "$HOME/.zshrc" 2>/dev/null ;;
  */bash) [ -f "$HOME/.bashrc" ] && . "$HOME/.bashrc" 2>/dev/null; [ -f "$HOME/.bash_profile" ] && . "$HOME/.bash_profile" 2>/dev/null ;;
esac

shellbrain init
