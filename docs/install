#!/usr/bin/env bash
set -eo pipefail

echo "installing shellbrain..."
echo ""

# Find python 3.11+ (check versioned binaries first, then fall back to python3/python)
PY=""
for candidate in python3.14 python3.13 python3.12 python3.11 python3 python; do
  if command -v "$candidate" &>/dev/null; then
    minor=$("$candidate" -c "import sys; print(sys.version_info.minor)" 2>/dev/null) || continue
    if [ "$minor" -ge 11 ]; then
      PY="$candidate"
      break
    fi
  fi
done

if [ -z "$PY" ]; then
  # Check if any python exists at all to give a better error
  if command -v python3 &>/dev/null || command -v python &>/dev/null; then
    FOUND_VER=$(python3 -c "import sys; print(f'{sys.version_info.major}.{sys.version_info.minor}')" 2>/dev/null || python -c "import sys; print(f'{sys.version_info.major}.{sys.version_info.minor}')" 2>/dev/null)
    echo "error: python $FOUND_VER found, but shellbrain requires python 3.11+."
  else
    echo "error: python not found."
  fi
  if [[ "$OSTYPE" =~ ^darwin ]]; then
    echo "install it with: brew install python@3.13"
  else
    echo "install python 3.11+ and try again."
  fi
  exit 1
fi

PY_VERSION=$($PY -c "import sys; print(f'{sys.version_info.major}.{sys.version_info.minor}')")
echo "using $PY ($PY_VERSION)"

# Install with fallback chain
$PY -m pip install --user --break-system-packages shellbrain 2>/dev/null \
  || $PY -m pip install --user shellbrain 2>/dev/null \
  || $PY -m pip install shellbrain

# Find the shellbrain binary
# 1. Ask Python where user scripts live
# 2. Try PATH directly
# 3. Check common locations
SHELLBRAIN=""
USER_BIN=$($PY -c "import sysconfig; print(sysconfig.get_path('scripts', 'posix_user'))" 2>/dev/null)

# pip --user installs scripts here — prefer the exact binary we just installed
if [ -n "$USER_BIN" ] && [ -x "$USER_BIN/shellbrain" ]; then
  SHELLBRAIN="$USER_BIN/shellbrain"
elif command -v shellbrain &>/dev/null; then
  SHELLBRAIN=shellbrain
fi

if [ -z "$SHELLBRAIN" ]; then
  # Last resort: check common locations
  for dir in "$HOME/.local/bin" "$HOME/Library/Python/$PY_VERSION/bin" "/usr/local/bin" "/opt/homebrew/bin"; do
    if [ -x "$dir/shellbrain" ]; then
      SHELLBRAIN="$dir/shellbrain"
      break
    fi
  done
fi

if [ -z "$SHELLBRAIN" ]; then
  echo ""
  echo "shellbrain was installed but could not be found."
  echo "restart your terminal, then run: shellbrain init"
  exit 0
fi

echo ""
echo "initializing..."
echo ""
$SHELLBRAIN init

echo ""
echo "shellbrain. knowledge compounds."
