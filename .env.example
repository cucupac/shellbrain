POSTGRES_DB=shellbrain
POSTGRES_USER=shellbrain_admin
POSTGRES_PASSWORD=shellbrain_admin
POSTGRES_PORT=5432
SHELLBRAIN_DB_DATA_DIR=./.local/postgres-data
SHELLBRAIN_DB_DSN=postgresql+psycopg://shellbrain_app:shellbrain@localhost:5432/shellbrain
SHELLBRAIN_DB_ADMIN_DSN=postgresql+psycopg://shellbrain_admin:shellbrain_admin@localhost:5432/shellbrain
SHELLBRAIN_BACKUP_DIR=~/.shellbrain/backups
# SHELLBRAIN_BACKUP_MIRROR_DIR=/path/to/external-or-synced-backup-dir
