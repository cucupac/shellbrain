POSTGRES_DB=<database-name>
POSTGRES_USER=<admin-user>
POSTGRES_PASSWORD=<admin-password>
POSTGRES_PORT=5432
SHELLBRAIN_DB_DATA_DIR=./.local/postgres-data
SHELLBRAIN_DB_DSN=postgresql+psycopg://<app-user>:<app-password>@localhost:5432/<database-name>
SHELLBRAIN_DB_ADMIN_DSN=postgresql+psycopg://<admin-user>:<admin-password>@localhost:5432/<database-name>
SHELLBRAIN_BACKUP_DIR=~/.shellbrain/backups
# SHELLBRAIN_BACKUP_MIRROR_DIR=/path/to/external-or-synced-backup-dir
